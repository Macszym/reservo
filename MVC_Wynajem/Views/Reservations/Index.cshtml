@model IEnumerable<Reservo.Models.Reservation>
@{
    ViewData["Title"] = "Moje rezerwacje";
    var userRole = Context.Session.GetString("UserRole");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@(userRole == "Admin" ? "Wszystkie rezerwacje" : "Moje rezerwacje")</h2>
        <a href="@Url.Action("Create")" class="btn btn-success">Nowa rezerwacja</a>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="row">
            @foreach (var reservation in Model)
            {
                <div class="col-lg-6 col-xl-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@reservation.Resource?.Name</h6>
                            <span class="badge @GetStatusBadgeClass(reservation.Status)">
                                @GetStatusDisplayName(reservation.Status)
                            </span>
                        </div>
                        <div class="card-body">
                            @if (reservation.Resource?.Category != null)
                            {
                                <span class="badge mb-2" style="background-color: @reservation.Resource.Category.Color">
                                    @reservation.Resource.Category.Name
                                </span>
                            }
                            
                            <div class="mb-2">
                                <strong>Od:</strong> @reservation.StartDate.ToString("dd.MM.yyyy HH:mm")<br>
                                <strong>Do:</strong> @reservation.EndDate.ToString("dd.MM.yyyy HH:mm")
                            </div>
                            
                            <div class="mb-2">
                                <strong>Czas:</strong> @((reservation.EndDate - reservation.StartDate).TotalHours.ToString("F1")) h
                            </div>
                            
                            @if (userRole == "Admin")
                            {
                                <div class="mb-2">
                                    <strong>Użytkownik:</strong> @reservation.User?.Username
                                </div>
                            }
                            
                            @if (!string.IsNullOrEmpty(reservation.Purpose))
                            {
                                <div class="mb-2">
                                    <strong>Cel:</strong> @reservation.Purpose
                                </div>
                            }
                            
                            <small class="text-muted">
                                Utworzono: @reservation.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100" role="group">
                                <a href="@Url.Action("Details", new { id = reservation.Id })" 
                                   class="btn btn-outline-primary btn-sm">
                                    Szczegóły
                                </a>
                                
                                @if (reservation.Status == Reservo.Models.ReservationStatus.Active && 
                                     reservation.StartDate > DateTime.Now)
                                {
                                    <a href="@Url.Action("Edit", new { id = reservation.Id })" 
                                       class="btn btn-outline-warning btn-sm">
                                        Edytuj
                                    </a>
                                    
                                    <form asp-action="Cancel" asp-route-id="@reservation.Id" method="post" 
                                          class="d-inline" onsubmit="return confirm('Czy na pewno chcesz anulować tę rezerwację?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Anuluj</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <h5>Brak rezerwacji</h5>
            <p>@(userRole == "Admin" ? "Nie ma żadnych rezerwacji w systemie." : "Nie masz jeszcze żadnych rezerwacji.")</p>
            <a href="@Url.Action("Create")" class="btn btn-success">Utwórz pierwszą rezerwację</a>
        </div>
    }

    <div class="mt-4">
        <a href="@Url.Action("Zalogowany", "IO")" class="btn btn-secondary">Powrót do panelu głównego</a>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(Reservo.Models.ReservationStatus status)
    {
        return status switch
        {
            Reservo.Models.ReservationStatus.Active => "bg-success",
            Reservo.Models.ReservationStatus.Completed => "bg-secondary",
            Reservo.Models.ReservationStatus.Cancelled => "bg-danger",
            _ => "bg-secondary"
        };
    }
    
    string GetStatusDisplayName(Reservo.Models.ReservationStatus status)
    {
        return status switch
        {
            Reservo.Models.ReservationStatus.Active => "Aktywna",
            Reservo.Models.ReservationStatus.Completed => "Zakończona", 
            Reservo.Models.ReservationStatus.Cancelled => "Anulowana",
            _ => status.ToString()
        };
    }
}