@model IEnumerable<Reservo.Models.User>
@{
    ViewData["Title"] = "Zarządzanie użytkownikami";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Zarządzanie użytkownikami</h2>
        <a href="@Url.Action("Rejestracja", "IO")" class="btn btn-success">Dodaj użytkownika</a>
    </div>
    
    <div class="card">
        <div class="card-body">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nazwa użytkownika</th>
                                <th>Rola</th>
                                <th>Klucz API</th>
                                <th>Data utworzenia</th>
                                <th>Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.Id</td>
                                    <td>@user.Username</td>
                                    <td>
                                        <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>
                                        <code class="small">@(user.ApiKey ?? "Brak")</code>
                                    </td>
                                    <td>@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <button type="button" class="btn btn-sm btn-outline-primary" 
                                                    onclick="showApiKey('@user.ApiKey')">
                                                Pokaż klucz
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <h5>Brak użytkowników</h5>
                    <p>Nie ma żadnych użytkowników w systemie.</p>
                </div>
            }
        </div>
    </div>
    
    <div class="mt-3">
        <a href="@Url.Action("Zalogowany", "IO")" class="btn btn-secondary">Powrót do panelu głównego</a>
    </div>
</div>

<!-- Modal do wyświetlania klucza API -->
<div class="modal fade" id="apiKeyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Klucz API</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Klucz API dla tego użytkownika:</p>
                <div class="input-group">
                    <input type="text" class="form-control" id="apiKeyValue" readonly>
                    <button class="btn btn-outline-secondary" type="button" onclick="copyApiKey()">
                        Kopiuj
                    </button>
                </div>
                <small class="text-muted">Ten klucz jest potrzebny do korzystania z REST API.</small>
            </div>
        </div>
    </div>
</div>

<script>
function showApiKey(apiKey) {
    document.getElementById('apiKeyValue').value = apiKey || 'Brak klucza';
    new bootstrap.Modal(document.getElementById('apiKeyModal')).show();
}

function copyApiKey() {
    const apiKeyInput = document.getElementById('apiKeyValue');
    apiKeyInput.select();
    document.execCommand('copy');
    
    // Pokaż feedback
    const button = event.target;
    const originalText = button.textContent;
    button.textContent = 'Skopiowano!';
    button.classList.remove('btn-outline-secondary');
    button.classList.add('btn-success');
    
    setTimeout(() => {
        button.textContent = originalText;
        button.classList.remove('btn-success');
        button.classList.add('btn-outline-secondary');
    }, 2000);
}
</script>