@{
    ViewData["Title"] = "Dodaj użytkownika";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Dodaj nowego użytkownika</h4>
                </div>
                <div class="card-body">
                    @if (ViewData["Error"] != null)
                    {
                        <div class="alert alert-danger">@ViewData["Error"]</div>
                    }
                    
                    @if (ViewData["Success"] != null)
                    {
                        <div class="alert alert-success">@ViewData["Success"]</div>
                    }

                    <form asp-action="Rejestracja" method="post">
                        <div class="form-group mb-3">
                            <label for="login">Nazwa użytkownika</label>
                            <input name="login" id="login" class="form-control" required />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="haslo">Hasło</label>
                            <input name="haslo" id="haslo" type="password" class="form-control" required />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="potwierdzHaslo">Potwierdź hasło</label>
                            <input name="potwierdzHaslo" id="potwierdzHaslo" type="password" class="form-control" required />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="rola">Rola</label>
                            <select name="rola" id="rola" class="form-control">
                                <option value="User">Użytkownik</option>
                                <option value="Admin">Administrator</option>
                            </select>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Dodaj użytkownika</button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="mt-3 text-center">
                <a href="@Url.Action("Users", "IO")" class="btn btn-secondary">Powrót do listy użytkowników</a>
            </div>
        </div>
    </div>
</div>
