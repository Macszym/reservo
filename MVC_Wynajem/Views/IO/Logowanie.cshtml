@{
    ViewData["Title"] = "Logowanie";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header text-center">
                    <h2>Reservo</h2>
                    <p class="mb-0">System Rezerwacji Zasobów</p>
                </div>
                <div class="card-body">
                    <h4 class="text-center mb-4">Logowanie</h4>

                    @if (ViewData["Error"] != null) {
                        <div class="alert alert-danger">@ViewData["Error"]</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Login:</label>
                            <input name="login" class="form-control" placeholder="Wprowadź login" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hasło:</label>
                            <input type="password" name="haslo" class="form-control" placeholder="Wprowadź hasło" required />
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Zaloguj się</button>
                        </div>
                    </form>
                    
                    <div class="text-center mt-3">
                        <small class="text-muted">
                            Demo: admin/admin lub user/user
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
